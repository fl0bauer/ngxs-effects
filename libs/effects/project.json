{
    "name": "effects",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/effects/src",
    "prefix": "lib",
    "projectType": "library",
    "release": {
        "version": {
            "manifestRootsToUpdate": ["dist/{projectRoot}"],
            "currentVersionResolver": "git-tag",
            "fallbackCurrentVersionResolver": "disk"
        }
    },
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/angular:package",
            "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
            "options": {
                "project": "libs/effects/ng-package.json",
                "tsConfig": "libs/effects/tsconfig.lib.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/effects/tsconfig.lib.prod.json"
                },
                "development": {}
            },
            "defaultConfiguration": "production"
        },
        "nx-release-publish": {
            "options": {
                "packageRoot": "dist/{projectRoot}"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/effects/jest.config.cts",
                "tsConfig": "libs/effects/tsconfig.spec.json"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
